#: includes/class-wayforpay-gateway.php:64
msgid "Enable/Disable"
msgstr "Включить или выключить"

#: includes/class-wayforpay-gateway.php:90
msgid "Merchant Secret key"
msgstr "Merchant Secret key"

#: includes/class-wayforpay-gateway.php:110
msgid "Select Page"
msgstr "Выберите страницу"

#. Plugin Name of the plugin
#: woocommerce-wayforpay-gateway.php
msgid "WooCommerce WayForPay Gateway"
msgstr "Платежный шлюз WayForPay для WooCommerce"

#. Plugin URI of the plugin
#: woocommerce-wayforpay-gateway.php
msgid "https://github.com/astappiev/woocommerce-wayforpay-gateway"
msgstr "https://github.com/astappiev/woocommerce-wayforpay-gateway"

#. Author of the plugin
#: woocommerce-wayforpay-gateway.php
msgid "Dev team WayForPay, Oleh Astappiev"
msgstr "Команда разработчиков WayForPay, Oleh Astappiev"

#: includes/class-wayforpay-gateway.php:66
msgid "Enable WayForPay Payment Engine"
msgstr "Включить платежную систему WayForPay"

#: includes/class-wayforpay-gateway.php:70
msgid "Title"
msgstr "Название платежного метода"

#: includes/class-wayforpay-gateway.php:73
msgid "This controls the title which user sees during checkout."
msgstr "Название платежного метода, которое может прочитать пользователь во время оплаты."

#: includes/class-wayforpay-gateway.php:77
msgid "Description"
msgstr "Описание платежного метода"

#. Description of the plugin
#: woocommerce-wayforpay-gateway.php
#: includes/class-wayforpay-gateway.php:79
msgid "Pay securely via the WayForPay Payment Engine."
msgstr "Оплачивайте безопасно через платежную систему WayForPay."

#: includes/class-wayforpay-gateway.php:80
msgid "This controls the description which user sees during checkout."
msgstr "Дополнительный комментарий об этом методе оплаты, который может прочитать пользователь во время оплаты."

#: includes/class-wayforpay-gateway.php:84
msgid "Merchant Account"
msgstr "Merchant Account"

#: includes/class-wayforpay-gateway.php:86
msgid "Seller identifier. This value is assigned to you by WayForPay."
msgstr "Идентификатор продавца. Это значение присваивается вам системой WayForPay."

#: includes/class-wayforpay-gateway.php:92
msgid "Signature secret key. This value is assigned to you by WayForPay."
msgstr "Секретный ключ продавца. Это значение присваивается вам системой WayForPay."

#: includes/class-wayforpay-gateway.php:96
msgid "Display Logo"
msgstr "Отображение логотипа"

#: includes/class-wayforpay-gateway.php:99
msgid "No logo"
msgstr "Без логотипа"

#: includes/class-wayforpay-gateway.php:100
msgid "WayForPay Logo"
msgstr "Логотип WayForPay"

#: includes/class-wayforpay-gateway.php:101
msgid "Payment Processors Logos"
msgstr "Логотипы платежных систем"

#: includes/class-wayforpay-gateway.php:104
msgid "Determines which logo is shown near this payment method on checkout."
msgstr "Определяет, какой логотип отображается возле этого способа оплаты на кассе."

#: includes/class-wayforpay-gateway.php:124
#, php-format
msgid "The value is controlled by the %s constant."
msgstr "Значение контролируется константой %s."

#: includes/class-wayforpay-gateway.php:372
#, php-format
msgid "Transaction updated, current status: %s"
msgstr "Транзакция обновлена, текущий статус: %s"

#: includes/class-wayforpay-gateway.php:320
#, php-format
msgid "Payment successful: %1$s %2$s."
msgstr "Платеж выполнен: %1$s %2$s."

#: includes/class-wayforpay-gateway.php:283
#: includes/class-wayforpay-gateway.php:354
#, php-format
msgid "Refunded %1$s %2$s."
msgstr "Возвращено %1$s из %2$s."

#: includes/class-wayforpay-gateway.php:368
msgid "Payment expired."
msgstr "Срок оплаты истек."

#: includes/class-wayforpay-gateway.php:362
#, php-format
msgid "Payment failed: %1$s - %2$s."
msgstr "Платеж не прошел: %1$s - %2$s."

#: includes/class-wayforpay-gateway.php:19
msgid "Accept card payments, Apple Pay and Google Pay via WayForPay payment gateway."
msgstr "Принимайте платежи по картам, Apple Pay и Google Pay через платежный шлюз WayForPay."

#: includes/class-wayforpay-gateway.php:72
msgid "Pay with card, Apple Pay, Google Pay"
msgstr "Оплата картой, Apple Pay, Google Pay"

#: includes/class-wayforpay-gateway.php:384
msgid "An error has occurred during redirect, if it persists, please contact us."
msgstr "Во время перенаправления произошла ошибка, если она не устраняется, пожалуйста, свяжитесь с нами."

#: includes/class-wayforpay-gateway.php:108
msgid "Return page"
msgstr "Страница возврата"

#: includes/class-wayforpay-gateway.php:111
msgid "The page where the user will be directed after payment. By default, it is the order status page."
msgstr "Страница, на которую будет направлен пользователь после оплаты. По умолчанию это страница состояния заказа."

#: includes/class-wayforpay-gateway.php:115
msgid "or specify the address"
msgstr "или укажите адрес"

#: includes/class-wayforpay-gateway.php:117
msgid "Alternatively, you can enter the URL of the page to redirect. Have a precedence over the previous option."
msgstr "Альтернативно можно ввести URL-адрес страницы для перенаправления. Имеет преимущество перед страницей."

#: includes/class-wayforpay-gateway.php:268
msgid "Not provided"
msgstr "Не предоставлено"

#: includes/class-wayforpay-gateway.php:282
msgid "Order refunded"
msgstr "Заказ возвращен"

#: includes/class-wayforpay-gateway.php:286
#, php-format
msgid "Refund failed: %1$s"
msgstr "Возврат не состоялся: %1$s"

#: includes/class-wayforpay-gateway.php:313
msgid "An error has occurred during processing. Please contact us to ensure your order has submitted."
msgstr "Во время обработки произошла ошибка. Пожалуйста, свяжитесь с нами, чтобы убедиться, что ваш заказ отправлен."

#: includes/class-wayforpay-gateway.php:388
#: includes/class-wayforpay-gateway.php:428
msgid "An error has occurred during processing. Signature is not valid."
msgstr "Во время обработки произошла ошибка. Подпись не действительна."

#: includes/class-wayforpay-gateway.php:414
msgid "Payment failed"
msgstr "Платеж не прошел"

#: includes/class-wayforpay-gateway.php:263
msgid "Transaction not found."
msgstr "Транзакция не найдена."

#: includes/class-wayforpay-gateway.php:322
#, php-format
msgid "Unexpected payment received: %1$s. The order could be double paid."
msgstr "Получен невыясненный платеж: %1$s. Заказ мог быть оплачен дважды."

#: includes/class-wayforpay-gateway.php:356
#, php-format
msgid "Got a refund, with a wrong order reference: %1$s."
msgstr "Получили возврат средств, с неверным номером: %1$s."

#: includes/class-wayforpay-gateway.php:456
msgid "Subscription not found for this renewal order."
msgstr "Подписка для продления этого заказа не найдена."

#: includes/class-wayforpay-gateway.php:462
msgid "No saved payment token found. The customer must update their payment method."
msgstr "Не найден сохраненный платежный токен. Клиент должен обновить свой способ оплаты."

#: includes/class-wayforpay-gateway.php:476
#, php-format
msgid "Subscription renewal payment successful: %1$s %2$s."
msgstr "Оплата продления подписки прошла успешно: %1$s %2$s."

#: includes/class-wayforpay-gateway.php:490
#, php-format
msgid "Subscription renewal failed: %s"
msgstr "Продление подписки не удалось: %s"

#: includes/class-wayforpay.php:144
msgid "Refund response signature is not valid."
msgstr "Подпись ответа на возврат не действительна."

#: includes/class-wayforpay-gateway.php:212
#, php-format
msgid "Order %s"
msgstr "Заказ %s"

#: includes/class-wayforpay-gateway.php:336
msgid "Recurring payment token saved for automatic renewals."
msgstr "Токен для автоматических продлений сохранен."

#: includes/class-wayforpay-gateway.php:341
msgid "Switched to manual renewal: no recurring payment token found."
msgstr "Переключено на ручное продление: не найден токен для автоматических продлений."

#: includes/class-wayforpay-gateway.php:345
msgid "Warning: Subscription(s) switched to manual renewal because no recurring payment token (recToken) was received from WayForPay."
msgstr "Внимание: Подписка(и) переключены на ручное продление, потому что не был получен токен для автоматических продлений (recToken) от WayForPay."
